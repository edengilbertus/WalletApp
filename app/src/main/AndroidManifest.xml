<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.WalletApp">

        <activity
            android:name=".WalletHomeActivity"
            android:exported="true"
            android:theme="@style/Theme.WalletApp.Orange">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".CardDetailsActivity"
            android:exported="false"
            android:theme="@style/Theme.WalletApp.Dark" />

        <activity
            android:name=".ExpensesActivity"
            android:exported="false"
            android:theme="@style/Theme.WalletApp.Light" />

    </application>

</manifest>
