<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Left circle -->
    <item
        android:left="0dp"
        android:top="0dp">
        <shape android:shape="oval">
            <stroke
                android:width="1.5dp"
                android:color="#000000"/>
            <size
                android:width="32dp"
                android:height="32dp"/>
            <solid android:color="#00000000"/>
        </shape>
    </item>
    <!-- Right circle (overlapping) -->
    <item
        android:left="20dp"
        android:top="0dp">
        <shape android:shape="oval">
            <stroke
                android:width="1.5dp"
                android:color="#000000"/>
            <size
                android:width="32dp"
                android:height="32dp"/>
            <solid android:color="#00000000"/>
        </shape>
    </item>
</layer-list>
